# Скопируйте этот файл в .env и установите нужные значения

# Connection strings
DB_URL=postgresql://postgres:your_secure_password_here@postgres:5432/myhouse
REDIS_URL=redis://:your_redis_password_here@redis:6379

# Конфигурация PostgreSQL
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=myhouse
DB_PORT=5432

# Конфигурация Redis
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# Конфигурация Backend
NODE_ENV=development
BACKEND_PORT=8000
