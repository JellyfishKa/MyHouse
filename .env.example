# Скопируйте этот файл в .env и установите нужные значения

# Конфигурация PostgreSQL
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=myhouse
DB_PORT=5432

# Конфигурация Redis
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# Конфигурация Backend
NODE_ENV=development
BACKEND_PORT=3000
